{
  "name": "@anycms/a2ui-react",
  "version": "0.2.0",
  "description": "React renderer for A2UI v1.0.",
  "license": "MIT",
  "author": "Liangdi <wu@liangdi.me>",
  "homepage": "https://github.com/anycms/a2ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anycms/a2ui.git",
    "directory": "packages/a2ui-react"
  },
  "bugs": {
    "url": "https://github.com/anycms/a2ui/issues"
  },
  "keywords": [
    "a2ui",
    "anycms",
    "generative-ui",
    "react",
    "renderer",
    "ai-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@anycms/a2ui-core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
