{
  "name": "@anycms/a2ui-transport-sse",
  "version": "0.1.0",
  "description": "SSE transport adapter for A2UI v1.0 (connects to the anycms-agent example 27 backend).",
  "license": "MIT",
  "author": "Liangdi <wu@liangdi.me>",
  "homepage": "https://github.com/anycms/a2ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anycms/a2ui.git",
    "directory": "packages/a2ui-transport-sse"
  },
  "bugs": {
    "url": "https://github.com/anycms/a2ui/issues"
  },
  "keywords": [
    "a2ui",
    "anycms",
    "generative-ui",
    "sse",
    "transport",
    "ai-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anycms/a2ui-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  }
}
