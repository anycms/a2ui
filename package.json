{
  "name": "a2ui-renderer-workspace",
  "private": true,
  "version": "0.1.1",
  "description": "A2UI v1.0 TypeScript renderer libraries (framework-agnostic core + React + SSE transport + gallery).",
  "license": "MIT",
  "author": "Liangdi <wu@liangdi.me>",
  "homepage": "https://github.com/anycms/a2ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anycms/a2ui.git"
  },
  "bugs": {
    "url": "https://github.com/anycms/a2ui/issues"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "dev": "pnpm -C packages/a2ui-gallery dev",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo node_modules/.cache",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "publish:npm": "pnpm -r run build && pnpm -r publish --access public --no-git-checks --registry https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@release-it/bumper": "^7.0.6",
    "release-it": "^20.2.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
